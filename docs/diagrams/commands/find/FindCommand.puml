@startuml
title Sequence Diagram: FindCommand

participant "Caller" as Caller
participant ":FindCommand" as Command
participant ":WorkoutList" as WorkoutList
participant ":Workout" as Workout
participant ":Exercise" as Exercise
participant ":Ui" as Ui
participant "Parser" as Parser

Caller -> Command : execute(workouts, ui)
activate Command

alt arguments.contains("e/")
    Command -> Command : handleFindExercise(workouts, ui)
    activate Command

    Command -> Parser : parseValue(arguments, "e/")
    Parser --> Command : exerciseKeyword
    Command -> Parser : parseValue(arguments, "w/")
    Parser --> Command : workoutName

    alt exerciseKeyword or workoutName missing
        Command -> Command : throw GitSwoleException(INCOMPLETE_COMMAND)
    end

    Command -> WorkoutList : getWorkoutByName(workoutName)
    activate WorkoutList
    WorkoutList --> Command : targetWorkout
    deactivate WorkoutList

    alt targetWorkout == null
        Command -> Command : throw GitSwoleException(IDX_OUTOFBOUNDS)
    end

    Command -> Workout : getExerciseList()
    activate Workout
    Workout --> Command : exercises
    deactivate Workout

    loop for each exercise in exercises
        Command -> Exercise : getExerciseName()
        activate Exercise
        Exercise --> Command : exerciseName
        deactivate Exercise

        alt exercise name contains exerciseKeyword
            Command -> Exercise : getWeight()
            activate Exercise
            Exercise --> Command : weight
            deactivate Exercise
            Command -> Exercise : getSets()
            activate Exercise
            Exercise --> Command : sets
            deactivate Exercise
            Command -> Exercise : getReps()
            activate Exercise
            Exercise --> Command : reps
            deactivate Exercise
            Command -> Ui : showMessage("name | Weight | Sets | Reps")
        end
    end

    alt !found
        Command -> Ui : showMessage("Exercise Not Found :(")
    end

    Command -> Ui : showLine()
    deactivate Command

else find workout (find w/...)
    Command -> Command : handleFindWorkout(workouts, ui)
    activate Command

    Command -> Parser : parseValue(arguments, "w/")
    Parser --> Command : keyword

    alt keyword missing
        Command -> Command : throw GitSwoleException(INCOMPLETE_COMMAND)
    end

    Command -> WorkoutList : getWorkouts()
    activate WorkoutList
    WorkoutList --> Command : workoutsList
    deactivate WorkoutList

    loop for each workout in workoutsList
        Command -> Workout : getWorkoutName()
        activate Workout
        Workout --> Command : workoutName
        deactivate Workout

        alt workout name contains keyword
            Command -> Workout : getExerciseList()
            activate Workout
            Workout --> Command : exerciseList
            deactivate Workout
            Command -> Ui : showMessage("name | Exercises: count")
        end
    end

    alt !found
        Command -> Ui : showLine()
        Command -> Ui : showMessage("Workout Not Found :(")
    end

    Command -> Ui : showLine()
    deactivate Command
end

Command --> Caller
deactivate Command

@enduml