@startuml
actor ":User" as User
participant ":FindCommand" as FC
participant ":WorkoutList" as WL
participant ":Ui" as UI
participant ":Workout" as W
participant ":Exercise" as E

User -> FC : execute(workouts, ui)
activate FC

FC -> FC : keyword.toLowerCase()

alt keyword is empty
    FC -> User : throw GitSwoleException
end

FC -> WL : getWorkouts()
activate WL
WL --> FC
deactivate WL

loop for each workout in workouts

    FC -> W : getWorkoutName()
    activate W
    W --> FC
    deactivate W

    alt workout name contains keyword
        FC -> W : getWorkoutName()
        activate W
        W --> FC
        deactivate W

        FC -> W : getExerciseList()
        activate W
        W --> FC
        deactivate W

        FC -> UI : showMessage("[Workout] ...")
        activate UI
        UI --> FC
        deactivate UI
    end

    FC -> W : getExerciseList()
    activate W
    W --> FC
    deactivate W

    loop for each exercise in workout

        FC -> E : getExerciseName()
        activate E
        E --> FC
        deactivate E

        alt exercise name contains keyword
            FC -> E : getExerciseName()
            activate E
            E --> FC
            deactivate E

            FC -> W : getWorkoutName()
            activate W
            W --> FC
            deactivate W

            FC -> E : getWeight()
            activate E
            E --> FC
            deactivate E

            FC -> E : getSets()
            activate E
            E --> FC
            deactivate E

            FC -> E : getReps()
            activate E
            E --> FC
            deactivate E

            FC -> UI : showMessage("[Exercise] ...")
            activate UI
            UI --> FC
            deactivate UI
        end
    end
end

alt no matches found
    FC -> UI : showMessage("No matching workouts or exercises found :(")
    activate UI
    UI --> FC
    deactivate UI
end

FC -> UI : showLine()
activate UI
UI --> FC
deactivate UI

FC --> User
deactivate FC

@enduml