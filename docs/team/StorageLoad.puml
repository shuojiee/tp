@startuml
title Sequence Diagram: Storage.load()

participant "Caller" as Caller
participant ":Storage" as Storage
participant ":WorkoutList" as WorkoutList
participant ":Scanner" as Scanner
participant ":Workout" as Workout
participant ":Exercise" as Exercise

Caller -> Storage : load()
activate Storage

Storage -> WorkoutList ** : new WorkoutList()

Storage -> Storage : check file.exists()
alt file does not exist
    Storage --> Caller : empty workoutList
else file exists
    Storage -> Scanner ** : new Scanner(file)
    activate Scanner

    loop scanner.hasNextLine()
        Storage -> Scanner : nextLine()
        Scanner --> Storage : line

        alt WORKOUT_TAG
            Storage -> Storage : parseWorkoutLine(parts)
            activate Storage
            Storage -> Workout ** : new Workout(name)
            Storage --> Storage : currentWorkout
            deactivate Storage

        else EXERCISE_TAG
            Storage -> Storage : parseExerciseLine(parts)
            activate Storage
            Storage -> Exercise ** : new Exercise(...)
            Storage --> Storage : exercise
            deactivate Storage

            Storage -> Workout : addExercise(exercise)
            activate Workout
            Workout --> Storage
            deactivate Workout

        else WORKOUT_SEPARATOR
            Storage -> WorkoutList : addWorkout(currentWorkout)
            activate WorkoutList
            WorkoutList --> Storage
            deactivate WorkoutList
        end
    end

    Storage -> Scanner : close() <<via try-with-resources>>
    deactivate Scanner
    destroy Scanner

    Storage --> Caller : workoutList
end
deactivate Storage
@enduml
